# AgentPay Backend Environment

# Server
API_PORT=3001
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentpay

# Redis (optional — degrades gracefully)
REDIS_URL=redis://localhost:6379

# 0G Network
ZG_RPC_URL=https://evmrpc-testnet.0g.ai
ZG_CHAIN_ID=16600

# 0G Storage & Compute (optional)
ZG_STORAGE_ENDPOINT=
ZG_COMPUTE_ENDPOINT=

# Contract Addresses (deployed)
NEXT_PUBLIC_AGENT_REGISTRY_ADDRESS=
NEXT_PUBLIC_PAYMENT_ROUTER_ADDRESS=
NEXT_PUBLIC_SPLIT_VAULT_ADDRESS=

# Deployer wallet (for on-chain transactions)
DEPLOYER_PRIVATE_KEY=
